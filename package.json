{
  "name": "spk-workers",
  "version": "1.0.0",
  "description": "Simple SPK Server on Cloudflare Workers",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "prebuild": "node scripts/build-templates.mjs",
    "build": "tsc",
    "upload": "node scripts/upload.mjs",
    "upload:config": "node scripts/upload.mjs --config",
    "upload:themes": "node scripts/upload.mjs --themes",
    "upload:public": "node scripts/upload.mjs --public",
    "deploy": "npm run build && node scripts/upload.mjs && node scripts/sync-access-bypass.mjs && wrangler deploy",
    "access:bypass:sync": "node scripts/sync-access-bypass.mjs",
    "db:create": "wrangler d1 create spks",
    "db:info": "wrangler d1 info spks",
    "db:list": "wrangler d1 list",
    "db:migrate": "wrangler d1 migrations apply spks --remote",
    "db:migrate:local": "wrangler d1 migrations apply spks --local",
    "db:migrate:list": "wrangler d1 migrations list spks",
    "db:migrate:create": "wrangler d1 migrations create spks",
    "db:execute": "wrangler d1 execute spks --remote",
    "db:execute:local": "wrangler d1 execute spks --local",
    "db:status": "node scripts/db-status.mjs",
    "db:status:json": "node scripts/db-status.mjs --json",
    "db:export": "node scripts/export-data.mjs --all",
    "db:export:packages": "node scripts/export-data.mjs --table packages",
    "db:export:arch": "node scripts/export-data.mjs --table package_arch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "mustache": "^4.2.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.4",
    "@cloudflare/workers-types": "^4.20240117.0",
    "@eslint/js": "^9.39.4",
    "@iarna/toml": "^2.2.5",
    "@playwright/test": "^1.58.2",
    "@types/mustache": "^4.2.5",
    "@types/node": "^20.11.5",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.1",
    "wrangler": "^4.82.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
